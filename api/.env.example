# Copy to api/.env — the app reads from .env, not this file.
DATABASE_URL=postgresql://user:password@localhost:5432/your_db
JWT_SECRET=your_jwt_secret_here

# Port for the API (default: 3000). Web runs on 3001 and proxies /api to this port.
# PORT=3000

# Comma-separated origins for CORS (e.g. http://localhost:3001 for web app). Leave empty to allow all.
# CORS_ORIGIN=http://localhost:3001
GOOGLE_CLIENT_ID=1018549727024-qd9g8a7mt77niinppquu2q6ulvho6e73.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

